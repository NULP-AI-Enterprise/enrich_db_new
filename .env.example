# ── Copy to .env and fill in real values ─────────────────────────────────────

# PostgreSQL (same DB as your Spring Boot backend)
DATABASE_URL=postgresql://advertising_user:advertising_pass@localhost:5432/advertising_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pipeline flags
USE_MOCK_LLM=true       # set to false in production
USE_MOCK_SEARCH=true    # set to false in production

# Tuning
BATCH_EMBED_SIZE=100
BATCH_EMBED_INTERVAL=30
SCRAPE_TIMEOUT=5.0
MAX_RETRIES=3
PRODUCER_PAGE_SIZE=500
LLM_RATE_LIMIT_DELAY=0.5
